package com.accelaero.ops.manager.model;

import com.fasterxml.jackson.annotation.JsonInclude;
import com.fasterxml.jackson.annotation.JsonProperty;
import lombok.AllArgsConstructor;
import lombok.Builder;
import lombok.Getter;
import lombok.NoArgsConstructor;
import lombok.Setter;
import lombok.ToString;

@ToString
@Getter
@Setter
@AllArgsConstructor
@NoArgsConstructor
@Builder
@JsonInclude(JsonInclude.Include.NON_NULL)
public class FR24FlightEventDto {

    @JsonProperty("aircraft_type")
    private String aircraftType;

    @JsonProperty("altitude_ft")
    private String altitudeFt;

    private String callsign;

    @JsonProperty("dest_iata")
    private String destIata;

    @JsonProperty("event_lat")
    private Double eventLat;

    @JsonProperty("event_lon")
    private Double eventLon;

    private String eta;

    @JsonProperty("event_time")
    private String eventTime;

    @JsonProperty("event_type")
    private String eventType;

    private String flight;

    @JsonProperty("flight_id")
    private String flightId;

    @JsonProperty("landed_at_iata")
    private String landedAtIata;

    @JsonProperty("landed_at_icao")
    private String landedAtIcao;

    @JsonProperty("last_airspace")
    private String lastAirspace;

    @JsonProperty("origin_iata")
    private String originIata;

    private String registration;

    @JsonProperty("service_type")
    private String serviceType;

    @JsonProperty("transponder_hex")
    private String transponderHex;
}
